{
  "id": "clap",
  "name": "CLAP FX",
  "abbrev": "CL",
  "version": "0.3.9",
  "description": "Host for CLAP audio effect plugins",
  "author": "charlesvestal",
  "license": "MIT",
  "dsp": "clap.so",
  "api_version": 2,
  "capabilities": {
    "audio_out": true,
    "audio_in": true,
    "chainable": true,
    "component_type": "audio_fx",
    "chain_params": [
      {
        "key": "plugin_id",
        "name": "Plugin",
        "type": "string"
      }
    ]
  },
  "assets": {
    "path": "plugins",
    "label": "CLAP Plugins",
    "extensions": [
      ".clap"
    ],
    "description": "Upload .clap audio effect plugins (ARM64 Linux)"
  }
}
